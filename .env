NODE_ENV=development
APP_PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=97531372
DB_NAME=welfare_db

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

AD_ENABLED=true
AD_URL=ldap://172.25.0.20:389
