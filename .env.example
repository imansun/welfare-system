NODE_ENV=development
APP_PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=welfare_db

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

AD_ENABLED=false
AD_URL=ldap://ad.example.local:389
AD_BASE_DN=DC=example,DC=local
AD_DOMAIN=EXAMPLE
AD_UPN_SUFFIX=example.local
AD_SEARCH_SCOPE=sub
AD_BIND_DN=ldap_reader@example.local
AD_BIND_PASSWORD=replace_with_ad_bind_password
AD_USERNAME_ATTR=sAMAccountName
AD_USER_FILTER=(&(objectCategory=person)(objectClass=user)(sAMAccountName={{username}}))
AD_GROUPS_ENABLED=false
AD_GROUPS_ATTR=memberOf

SWAGGER_PATH=api/docs
